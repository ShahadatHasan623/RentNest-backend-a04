model RentalRequest {
   id         String       @id @default(uuid(7))
   tenantId   String
   tenant     User         @relation("TenantRentals", fields: [tenantId], references: [id])
   propertyId String
   property   Properties   @relation(fields: [propertyId], references: [id], onDelete: Cascade)
   landlordId String
   landlord   User         @relation("LandlordRequests", fields: [landlordId], references: [id], onDelete: Cascade)
   payment    Payment?
   moveInDate DateTime
   duration   Int
   status     RentalStatus @default(PENDING)
   createdAt  DateTime     @default(now())
   updatedAt  DateTime     @updatedAt
}
